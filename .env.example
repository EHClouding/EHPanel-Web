DEBUG=false
SECRET_KEY=change_me
DBTOOLS_CREDENTIAL_KEY=change_me_independent_credential_key
DBTOOLS_SSO_SECRET=change_me_independent_dbtools_sso_secret
WEBMAIL_SSO_SECRET=change_me_independent_webmail_sso_secret
WEBMAIL_SSO_URL=
ALLOWED_HOSTS=panel.theflakito.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://panel.theflakito.com
SECURE_SSL_REDIRECT=false
SECURE_PROXY_SSL_HEADER=true
TRUSTED_PROXY_IPS=127.0.0.1,::1

DATABASE_URL=postgres://ehpanel_web:change_me@127.0.0.1:5432/ehpanel_web
REDIS_URL=redis://127.0.0.1:6379/0
CHANNEL_LAYER_BACKEND=redis

INTERNAL_BILLING_API_TOKEN=change_me_shared_with_billing
BILLING_WEBHOOK_TOKEN=
BILLING_API_BASE=https://panel.ehclouding.com/api/v1
BILLING_API_TOKEN=

HOSTING_PROVISIONING_MODE=local
HOSTING_DEFAULT_WEB_ENGINE=openlitespeed
LOCAL_PANEL_HOSTNAME=web01.ehclouding.com
LOCAL_PANEL_DATACENTER=hetzner-fsn1
LOCAL_PUBLIC_IP=
LOCAL_PROVISIONING_HELPER=/usr/local/sbin/ehpanel-local-provision
LOCAL_PROVISIONING_DRY_RUN=false
LOCAL_PROVISIONING_SUDO=true
LOCAL_HOME_ROOT=/home
LOCAL_NGINX_VHOSTS_DIR=/etc/nginx/conf.d
LOCAL_OLS_HOME=/usr/local/lsws
LOCAL_OLS_BACKEND_PORT=8088
LOCAL_PROVISION_DNS=true
LOCAL_PROVISION_SSL=true
LOCAL_PROVISION_MAIL=true
LOCAL_WEBMAIL_ENABLED=true
LOCAL_WEBMAIL_ROOT=/opt/ehpanel-webmail
LOCAL_WEBMAIL_PORT=8012
LOCAL_DOVECOT_PASSWD_FILE=/etc/dovecot/ehpanel-users
LOCAL_POSTFIX_VIRTUAL_DOMAINS_FILE=/etc/postfix/ehpanel-virtual-domains
LOCAL_POSTFIX_VIRTUAL_MAILBOXES_FILE=/etc/postfix/ehpanel-virtual-mailboxes
LOCAL_FILE_MANAGER_TEMP_ROOT=/opt/ehpanel/web/media/file-manager
LOCAL_MOODLE_DOWNLOAD_URL=

AGENT_CLOCK_SKEW_SECONDS=90
AGENT_HEARTBEAT_TIMEOUT_SECONDS=45
AGENT_ALLOW_LEGACY_RESUME=false
